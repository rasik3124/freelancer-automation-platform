# ── Backend Settings ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth Secrets (RELIANCE ON ENVIRONMENT VARIABLES) ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# ── Frontend API (Vite — injected at build time) ──────────────────────────────
# Set this to your deployed backend URL in production.
# example: VITE_API_URL=https://api.crescentblack.com
VITE_API_URL=http://localhost:3000

# ── Socket.io / CORS ──────────────────────────────────────────────────────────
# URL of the React frontend
FRONTEND_URL=http://localhost:3000

# ── n8n Automation (AI Chat & Lead Analysis) ───────────────────────────────────
# POST /api/chat forwards user messages to this n8n webhook.
N8N_WEBHOOK_URL=https://your-n8n-instance.cloud/webhook/chat
# Specifically for the lead analyzer button if different
N8N_LEAD_ANALYZE_URL=https://your-n8n-instance.cloud/webhook/lead-analyze
# (Optional) Header and/or query param auth for n8n
# N8N_API_KEY=your_n8n_api_key_here

# ── Email SMTP (optional — for notifications/reset) ───────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@crescentblack.com

# ── Infrastructure (optional) ──────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
